APP_NAME="BookStore"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bookstore
DB_USERNAME=root
DB_PASSWORD=
DB_COLLATION=utf8mb4_unicode_ci

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@bookstore.com"
MAIL_FROM_NAME="${APP_NAME}"

# BookStore Custom Config (overridden by Admin → Store settings when configured)
FREE_SHIPPING_THRESHOLD=99
FLAT_SHIPPING_RATE=15
STORE_PHONE="+971 50 000 0000"
STORE_ADDRESS="Dubai, UAE"
CURRENCY_SYMBOL=AED
CURRENCY_CODE=AED

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_CURRENCY=aed
